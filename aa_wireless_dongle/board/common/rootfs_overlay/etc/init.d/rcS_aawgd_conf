#!/bin/sh
#
# Setup AAWG configuration
#
set -o allexport

if [ -z "$AAWG_CONF_SOURCED" ]; then
	echo "Source /etc/aawgd.conf"
	source /etc/aawgd.conf
	export AAWG_CONF_SOURCED=1
fi


## Setup Wifi password
## - STA mode: SSID/password must be explicitly configured (no defaults)
## - AP mode: if password is not set, generate a random one for convenience
AAWG_WIFI_MODE="${AAWG_WIFI_MODE:-sta}"
if [ "${AAWG_WIFI_MODE}" = "ap" ]; then
	if [ -z "${AAWG_WIFI_PASSWORD}" ]; then
		export AAWG_WIFI_PASSWORD="$(cat /dev/urandom | tr -dc 'A-Za-z0-9@#' | head -c 16)"
	fi
fi

set +o allexport