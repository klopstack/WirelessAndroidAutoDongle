#!/bin/sh
#
# Start wifi services for STA/AP mode selected in /etc/aawgd.conf
#

set -e

case "$1" in
	start)
		if [ -z "$AAWG_CONF_SOURCED" ]; then
			echo "Source /etc/aawgd.conf"
			source /etc/aawgd.conf
		fi

		WIFI_MODE="${AAWG_WIFI_MODE:-sta}"

		if [ "$WIFI_MODE" = "ap" ]; then
			echo "Starting AP services (hostapd + dnsmasq)"

			# Ensure hostapd config exists (generated by S39hostapd_conf)
			if [ ! -f /var/run/hostapd.conf ]; then
				/etc/init.d/S39hostapd_conf start || true
			fi

			ifup wlan0 || true

			# Start hostapd + dnsmasq in background
			if command -v hostapd >/dev/null 2>&1; then
				hostapd -B /var/run/hostapd.conf || true
			fi

			if command -v dnsmasq >/dev/null 2>&1; then
				dnsmasq -C /etc/dnsmasq.conf || true
			fi
		else
			echo "Starting STA networking (ifup wlan0)"
			ifup wlan0 || true
		fi
		;;
	*)
		echo "Usage: $0 {start}"
		exit 1
esac

exit $?

