#!/bin/sh
#
# Prefer persistent bluetooth state on /persist when that partition is mounted.
# /var/lib/bluetooth is a tmpfs from fstab (before bluez) so pairing survives
# only if we replace it with a bind mount here (S06 runs before S40bluetoothd).
#

set +e

case "$1" in
	start)
		if ! mountpoint -q /persist 2>/dev/null; then
			exit 0
		fi
		mkdir -p /persist/bluetooth
		umount /var/lib/bluetooth 2>/dev/null || true
		mount --bind /persist/bluetooth /var/lib/bluetooth || \
			mount -t tmpfs -o size=16m,mode=0755 tmpfs /var/lib/bluetooth
		;;
	stop)
		if mountpoint -q /var/lib/bluetooth 2>/dev/null; then
			umount /var/lib/bluetooth 2>/dev/null || true
		fi
		;;
	*)
		echo "Usage: $0 {start|stop}"
		exit 1
		;;
esac

exit 0
