# NOTE:
# This file is a baseline/default. On boot, `S30wifi_mode` overwrites
# `/etc/network/interfaces` based on `/etc/aawgd.conf` (STA vs AP mode).
# Edit `/etc/aawgd.conf` instead of editing this file.

auto lo
iface lo inet loopback

auto wlan0
iface wlan0 inet dhcp
  pre-up wpa_supplicant -D nl80211 -i wlan0 -c /etc/wpa_supplicant.conf -B
  post-down killall -q wpa_supplicant

